# Server port (Render will override with PORT env var)
PORT=4000

# MongoDB Atlas connection string (without database name)
# Format: mongodb+srv://<username>:<password>@<cluster-url>
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>

# JWT Secret for token signing (generate a secure random string)
JWT_SECRET=replace_with_a_secure_random_string_min_32_chars

# Admin login credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_password

# Cloudinary credentials for image uploads
CLOUDINARY_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_SECRET_KEY=your_cloudinary_secret_key

# Razorpay payment gateway credentials
KEY_ID=your_razorpay_key_id
KEY_SECRET=your_razorpay_key_secret
CURRENCY=INR

# CORS allowed origins (comma-separated, no trailing slashes)
# Local dev: http://localhost:5173,http://localhost:5174
# Production: https://your-frontend.vercel.app,https://your-admin.vercel.app
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
